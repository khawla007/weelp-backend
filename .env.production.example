# Production Environment Template
# Copy to .env on production server and fill in real values
# DO NOT commit actual production values

APP_NAME=Weelp
APP_ENV=production
APP_KEY=  # Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-production-domain.com

# Reverse-proxy CIDR ranges that may set X-Forwarded-* headers.
# Examples: AWS ALB → "*" (ALB strips client header); Cloudflare → list from
# https://www.cloudflare.com/ips/; nginx on same host → "127.0.0.1".
# REQUIRED — boot throws if unset when APP_ENV=production.
TRUSTED_PROXIES=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=database

CACHE_STORE=database

JWT_SECRET=  # Generate with: php artisan jwt:secret --show

FRONTEND_URL=https://your-production-domain.com

STRIPE_SECRET_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

MINIO_KEY=
MINIO_SECRET=
MINIO_REGION=
MINIO_BUCKET=
MINIO_ENDPOINT=

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Weelp

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
